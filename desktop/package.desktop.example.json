{
  "name": "blu-sky-desktop",
  "version": "0.1.0",
  "description": "Desktop wrapper for blu sky messenger.",
  "main": "desktop/electron-main.js",
  "scripts": {
    "desktop": "electron .",
    "desktop:pack": "electron-builder"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.blusky.messenger",
    "productName": "blu sky",
    "files": [
      "index.html",
      "styles.css",
      "script.js",
      "manifest.webmanifest",
      "sw.js",
      "assets/**/*",
      "desktop/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
